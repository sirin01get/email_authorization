{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rare",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./email_authorization/web-app"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "SUPABASE_SCHEMA": "prototypes",
    "SUPABASE_ITEMS_TABLE": "items",
    "FREE_ITEM_LIMIT": "3",
    "ALLOWED_ORIGIN": "*"
  }
}
